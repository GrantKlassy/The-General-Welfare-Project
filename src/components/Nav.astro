---
import LanguageSwitcher from "./LanguageSwitcher.astro";
import { type Locale } from "../i18n";

interface Props {
  locale?: Locale;
  currentPath?: string;
}

const { locale = "en", currentPath = "/" } = Astro.props;
---

<nav
  class="sticky top-0 z-10 border-b border-neutral-800 bg-[var(--color-bg)] px-4 py-3 sm:px-6"
>
  <LanguageSwitcher currentLocale={locale} currentPath={currentPath} />
</nav>
