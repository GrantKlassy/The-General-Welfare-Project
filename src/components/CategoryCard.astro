---
interface Props {
  title: string;
  description: string;
  href: string;
}

const { title, description, href } = Astro.props;
---

<a
  href={href}
  class="block rounded-lg border border-neutral-800 px-6 py-5 text-center transition-colors hover:border-neutral-600 hover:bg-neutral-900"
>
  <h2 class="text-xl font-bold">{title}</h2>
  <p class="mt-1 text-gray-400">{description}</p>
</a>
