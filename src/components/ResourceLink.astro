---
interface Props {
  href: string;
  title: string;
  description: string;
}

const { href, title, description } = Astro.props;
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  class="block rounded-lg border border-neutral-800 px-5 py-4 transition-colors hover:border-neutral-600 hover:bg-neutral-900"
>
  <span class="font-bold">{title}</span>
  <span class="mt-1 block text-sm text-gray-400">{description}</span>
</a>
