---
interface Props {
  href: string;
  title: string;
  description: string;
}

const { href, title, description } = Astro.props;
---

<a
  href={href}
  target="_blank"
  rel="noopener"
  class="block min-h-16 rounded-lg border border-neutral-800 px-5 py-5 transition-colors hover:border-neutral-600 hover:bg-neutral-900 sm:px-6 sm:py-6"
>
  <span class="font-bold">{title}</span>
  <span class="mt-1 block">{description}</span>
</a>
