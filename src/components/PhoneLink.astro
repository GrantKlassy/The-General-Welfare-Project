---
interface Props {
  tel: string;
  label: string;
  desc: string;
  ariaLabel?: string;
}

const { tel, label, desc, ariaLabel } = Astro.props;
---

<a
  href={`tel:${tel}`}
  aria-label={ariaLabel ?? `${label} — ${desc}`}
  class="block min-h-[72px] rounded-lg border-2 border-neutral-700 px-5 py-5 transition-colors hover:border-neutral-500 hover:bg-neutral-900 sm:px-6 sm:py-6"
>
  <span class="block text-2xl font-bold">{label}</span>
  <span class="mt-1 block">{desc}</span>
</a>
