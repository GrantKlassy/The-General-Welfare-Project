---
import Base from "../layouts/Base.astro";
import ResourceLink from "../components/ResourceLink.astro";
---

<Base title="Voting — The General Welfare Project" currentPath="/voting">
  <div class="mx-auto max-w-3xl px-6 py-16">
    <h1 class="text-4xl font-bold">Voting</h1>
    <p class="mt-4 text-lg text-gray-300">
      Registration, polling info, voter ID laws, and election protection.
    </p>

    <section class="mt-10">
      <h2 class="text-2xl font-bold"><span class="text-flag-red">[[[</span> ★ Know Your Rights ★ <span class="text-flag-red">]]]</span></h2>
      <div class="mt-4 grid gap-3">
        <ResourceLink
          href="https://duckduckgo.com/?q=voter+registration"
          title="Voter Registration"
          description="Check your registration status and register to vote in your state"
        />
        <ResourceLink
          href="https://duckduckgo.com/?q=voter+id+requirements"
          title="Voter ID Requirements"
          description="What ID you need to vote — varies by state"
        />
      </div>
    </section>

    <section class="mt-10">
      <h2 class="text-2xl font-bold">[[[ ★ Get Help ★ ]]]</h2>
      <div class="mt-4 grid gap-3">
        <ResourceLink
          href="https://duckduckgo.com/?q=find+your+polling+place"
          title="Find Your Polling Place"
          description="Locate where to vote, check hours, and see what's on your ballot"
        />
        <ResourceLink
          href="https://duckduckgo.com/?q=election+protection+resources"
          title="Election Protection Resources"
          description="Report voter intimidation and get help with voting problems"
        />
      </div>
    </section>

    <section class="mt-10">
      <h2 class="text-2xl font-bold"><span class="text-flag-blue">[[[</span> ★ Call Now ★ <span class="text-flag-blue">]]]</span></h2>
      <div class="mt-4 grid gap-3">
        <a
          href="tel:866-687-8683"
          class="block rounded-lg border border-neutral-800 px-5 py-4 transition-colors hover:border-neutral-600 hover:bg-neutral-900"
        >
          <span class="font-bold">866-OUR-VOTE (866-687-8683)</span>
          <span class="mt-1 block text-sm text-gray-400"
            >Election Protection Hotline — nonpartisan voter assistance</span
          >
        </a>
      </div>
    </section>

    <a href="/" class="mt-12 inline-block text-gray-400 hover:text-white"
      >&larr; All topics</a
    >
  </div>
</Base>
