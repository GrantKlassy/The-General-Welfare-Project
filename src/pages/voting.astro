---
import Base from "../layouts/Base.astro";
import CategorySection from "../components/CategorySection.astro";
import { t } from "../i18n";
---

<Base
  title={`${t("en", "voting.title")} — ${t("en", "site.title")}`}
  currentPath="/voting"
>
  <CategorySection
    locale="en"
    title={t("en", "voting.title")}
    intro={t("en", "voting.pageDesc")}
    callNow={[
      {
        tel: "866-687-8683",
        label: t("en", "voting.phone"),
        desc: t("en", "voting.phoneDesc"),
      },
    ]}
    getHelp={[
      {
        href: "https://www.vote.org/polling-place-locator/",
        title: t("en", "voting.pollingPlace"),
        description: t("en", "voting.pollingPlaceDesc"),
      },
      {
        href: "https://866ourvote.org",
        title: t("en", "voting.electionProtection"),
        description: t("en", "voting.electionProtectionDesc"),
      },
    ]}
    knowYourRights={[
      {
        href: "https://vote.gov",
        title: t("en", "voting.registration"),
        description: t("en", "voting.registrationDesc"),
      },
      {
        href: "https://www.vote.org/voter-id-laws/",
        title: t("en", "voting.voterId"),
        description: t("en", "voting.voterIdDesc"),
      },
    ]}
  />
</Base>
