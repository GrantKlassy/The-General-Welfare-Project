---
import Base from "../layouts/Base.astro";
import CategorySection from "../components/CategorySection.astro";
import { t } from "../i18n";
---

<Base
  title={`${t("en", "freeSpeech.title")} — ${t("en", "site.title")}`}
  currentPath="/free-speech"
>
  <CategorySection
    locale="en"
    title={t("en", "freeSpeech.title")}
    intro={t("en", "freeSpeech.pageDesc")}
    callNow={[
      {
        tel: "212-679-5100",
        label: t("en", "freeSpeech.phone"),
        desc: t("en", "freeSpeech.phoneDesc"),
      },
    ]}
    getHelp={[
      {
        href: "https://www.aclu.org/contact-us",
        title: t("en", "freeSpeech.legalSupport"),
        description: t("en", "freeSpeech.legalSupportDesc"),
      },
      {
        href: "https://www.nlg.org/know-your-rights/",
        title: t("en", "freeSpeech.knowRightsProtest"),
        description: t("en", "freeSpeech.knowRightsProtestDesc"),
      },
    ]}
    knowYourRights={[
      {
        href: "https://www.aclu.org/issues/free-speech",
        title: t("en", "freeSpeech.firstAmendment"),
        description: t("en", "freeSpeech.firstAmendmentDesc"),
      },
      {
        href: "https://www.aclu.org/know-your-rights/protesters-rights",
        title: t("en", "freeSpeech.protest"),
        description: t("en", "freeSpeech.protestDesc"),
      },
    ]}
  />
</Base>
