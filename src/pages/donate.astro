---
import Base from "../layouts/Base.astro";
import { t } from "../i18n";
---

<Base
  title={`${t("en", "donate.title")} — ${t("en", "site.title")}`}
  currentPath="/donate"
>
  <div class="mx-auto max-w-3xl px-4 py-10 text-center sm:px-6 sm:py-16">
    <h1 class="text-3xl font-bold uppercase sm:text-4xl">
      {t("en", "donate.message")}
    </h1>

    <a href="/" class="mt-10 inline-block hover:text-white sm:mt-12"
      >[[[ {t("en", "common.home")} ]]]</a
    >
  </div>
</Base>
