---
import Base from "../layouts/Base.astro";
import CategorySection from "../components/CategorySection.astro";
import { t } from "../i18n";
---

<Base
  title={`${t("en", "housing.title")} — ${t("en", "site.title")}`}
  currentPath="/housing"
>
  <CategorySection
    locale="en"
    title={t("en", "housing.title")}
    intro={t("en", "housing.pageDesc")}
    callNow={[
      {
        tel: "211",
        label: t("en", "housing.phone"),
        desc: t("en", "housing.phoneDesc"),
      },
    ]}
    getHelp={[
      {
        href: "https://www.hud.gov/topics/rental_assistance",
        title: t("en", "housing.assistance"),
        description: t("en", "housing.assistanceDesc"),
      },
      {
        href: "https://www.lsc.gov/about-lsc/what-legal-aid/get-legal-help",
        title: t("en", "housing.legalAid"),
        description: t("en", "housing.legalAidDesc"),
      },
    ]}
    knowYourRights={[
      {
        href: "https://www.hud.gov/topics/rental_assistance/tenantrights",
        title: t("en", "housing.tenantRights"),
        description: t("en", "housing.tenantRightsDesc"),
      },
      {
        href: "https://www.lawhelp.org",
        title: t("en", "housing.eviction"),
        description: t("en", "housing.evictionDesc"),
      },
    ]}
  />
</Base>
