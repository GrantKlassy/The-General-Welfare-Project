---
import Base from "../layouts/Base.astro";
import ResourceLink from "../components/ResourceLink.astro";
---

<Base title="Housing — The General Welfare Project" currentPath="/housing">
  <div class="mx-auto max-w-3xl px-6 py-16">
    <h1 class="text-4xl font-bold">Housing</h1>
    <p class="mt-4 text-lg text-gray-300">
      Tenant rights, eviction defense, and housing assistance programs.
    </p>

    <section class="mt-10">
      <h2 class="text-2xl font-bold"><span class="text-flag-red">[[[</span> ★ Know Your Rights ★ <span class="text-flag-red">]]]</span></h2>
      <div class="mt-4 grid gap-3">
        <ResourceLink
          href="https://www.hud.gov/topics/rental_assistance/tenantrights"
          title="Your Landlord Can't Do That"
          description="You have the legal right to a safe home, your deposit back, and a fair lease. Here's what landlords are NOT allowed to do to you."
        />
        <ResourceLink
          href="https://www.usa.gov/legal-aid"
          title="You Can Fight an Eviction"
          description="You don't have to just leave. You have legal rights in the eviction process — and free lawyers who will help you fight it."
        />
      </div>
    </section>

    <section class="mt-10">
      <h2 class="text-2xl font-bold">[[[ ★ Get Help ★ ]]]</h2>
      <div class="mt-4 grid gap-3">
        <ResourceLink
          href="https://www.hud.gov/topics/rental_assistance"
          title="Apply for Rental Assistance Now"
          description="You may qualify for help paying rent right now. Apply for emergency rental assistance, Section 8, or public housing through your local housing authority."
        />
        <ResourceLink
          href="https://www.lsc.gov/about-lsc/what-legal-aid/get-legal-help"
          title="Get a Free Lawyer for Your Housing Case"
          description="You can get a free attorney for eviction defense, unsafe conditions, or landlord disputes. Legal aid is real, it's free, and it exists in every state."
        />
      </div>
    </section>

    <section class="mt-10">
      <h2 class="text-2xl font-bold"><span class="text-flag-blue">[[[</span> ★ Call Now ★ <span class="text-flag-blue">]]]</span></h2>
      <div class="mt-4 grid gap-3">
        <a
          href="tel:211"
          class="block rounded-lg border border-neutral-800 px-5 py-4 transition-colors hover:border-neutral-600 hover:bg-neutral-900"
        >
          <span class="font-bold">211</span>
          <span class="mt-1 block text-sm text-gray-400"
            >Local housing assistance and social services referrals</span
          >
        </a>
      </div>
    </section>

    <a href="/" class="mt-12 inline-block text-gray-400 hover:text-white"
      >&larr; All topics</a
    >
  </div>
</Base>
