---
import Base from "../../layouts/Base.astro";
import { t, localePath, type Locale } from "../../i18n";

export function getStaticPaths() {
  return [
    { params: { locale: "es" } },
    { params: { locale: "zh-Hans" } },
    { params: { locale: "vi" } },
    { params: { locale: "fil" } },
    { params: { locale: "ko" } },
    { params: { locale: "ja" } },
    { params: { locale: "ar" } },
    { params: { locale: "ht" } },
  ];
}

const locale = Astro.params.locale as Locale;
---

<Base
  title={`${t(locale, "donate.title")} — ${t(locale, "site.title")}`}
  lang={locale}
  currentPath="/donate"
>
  <div class="mx-auto max-w-3xl px-4 py-10 text-center sm:px-6 sm:py-16">
    <h1 class="text-3xl font-bold uppercase sm:text-4xl">
      {t(locale, "donate.message")}
    </h1>

    <a
      href={localePath(locale, "/")}
      class="mt-10 inline-block hover:text-white sm:mt-12"
      >[[[ {t(locale, "common.home")} ]]]</a
    >
  </div>
</Base>
