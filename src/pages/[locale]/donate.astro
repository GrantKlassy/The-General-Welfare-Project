---
import Base from "../../layouts/Base.astro";
import { t, localePath, type Locale } from "../../i18n";

export function getStaticPaths() {
  return [
    { params: { locale: "es" } },
    { params: { locale: "zh" } },
    { params: { locale: "vi" } },
  ];
}

const locale = Astro.params.locale as Locale;
---

<Base
  title={`${t(locale, "donate.title")} — ${t(locale, "site.title")}`}
  lang={locale}
  currentPath="/donate"
>
  <div class="mx-auto max-w-3xl px-4 py-16 text-center sm:px-6">
    <h1 class="text-4xl font-bold uppercase">
      {t(locale, "donate.message")}
    </h1>

    <a
      href={localePath(locale, "/")}
      class="mt-12 inline-block text-gray-400 hover:text-white"
      >&larr; {t(locale, "common.allTopics")}</a
    >
  </div>
</Base>
