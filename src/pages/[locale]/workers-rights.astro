---
import Base from "../../layouts/Base.astro";
import CategorySection from "../../components/CategorySection.astro";
import { t, type Locale } from "../../i18n";

export function getStaticPaths() {
  return [
    { params: { locale: "es" } },
    { params: { locale: "zh-Hans" } },
    { params: { locale: "vi" } },
    { params: { locale: "fil" } },
    { params: { locale: "ko" } },
    { params: { locale: "ja" } },
    { params: { locale: "ar" } },
    { params: { locale: "ht" } },
  ];
}

const locale = Astro.params.locale as Locale;
---

<Base
  title={`${t(locale, "workers.title")} — ${t(locale, "site.title")}`}
  lang={locale}
  currentPath="/workers-rights"
>
  <CategorySection
    locale={locale}
    title={t(locale, "workers.title")}
    intro={t(locale, "workers.pageDesc")}
    callNow={[
      {
        tel: "1-866-487-2365",
        label: t(locale, "workers.phone"),
        desc: t(locale, "workers.phoneDesc"),
      },
    ]}
    getHelp={[
      {
        href: "https://www.dol.gov/agencies/whd/contact/complaints",
        title: t(locale, "workers.complaint"),
        description: t(locale, "workers.complaintDesc"),
      },
      {
        href: "https://www.careeronestop.org/LocalHelp/UnemploymentBenefits/find-unemployment-benefits.aspx",
        title: t(locale, "workers.unemployment"),
        description: t(locale, "workers.unemploymentDesc"),
      },
    ]}
    knowYourRights={[
      {
        href: "https://www.dol.gov/agencies/whd/workers",
        title: t(locale, "workers.wageHour"),
        description: t(locale, "workers.wageHourDesc"),
      },
      {
        href: "https://www.osha.gov/workers/file-complaint",
        title: t(locale, "workers.safety"),
        description: t(locale, "workers.safetyDesc"),
      },
    ]}
  />
</Base>
