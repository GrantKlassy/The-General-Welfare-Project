---
import Base from "../../layouts/Base.astro";
import CategorySection from "../../components/CategorySection.astro";
import { t, type Locale } from "../../i18n";

export function getStaticPaths() {
  return [
    { params: { locale: "es" } },
    { params: { locale: "zh-Hans" } },
    { params: { locale: "vi" } },
    { params: { locale: "fil" } },
    { params: { locale: "ko" } },
    { params: { locale: "ja" } },
  ];
}

const locale = Astro.params.locale as Locale;
---

<Base
  title={`${t(locale, "food.title")} — ${t(locale, "site.title")}`}
  lang={locale}
  currentPath="/food"
>
  <CategorySection
    locale={locale}
    title={t(locale, "food.title")}
    intro={t(locale, "food.pageDesc")}
    callNow={[
      {
        tel: "+18663486479",
        label: t(locale, "food.phone"),
        desc: t(locale, "food.phoneDesc"),
      },
    ]}
    getHelp={[
      {
        href: "https://www.feedingamerica.org/find-your-local-foodbank",
        title: t(locale, "food.foodBank"),
        description: t(locale, "food.foodBankDesc"),
      },
      {
        href: "https://www.fns.usda.gov/snap/state-directory",
        title: t(locale, "food.snapApply"),
        description: t(locale, "food.snapApplyDesc"),
      },
    ]}
    knowYourRights={[
      {
        href: "https://www.fns.usda.gov/snap/recipient/eligibility",
        title: t(locale, "food.snapEligibility"),
        description: t(locale, "food.snapEligibilityDesc"),
      },
      {
        href: "https://www.fns.usda.gov/cn/applying-free-and-reduced-price-school-meals",
        title: t(locale, "food.schoolMeals"),
        description: t(locale, "food.schoolMealsDesc"),
      },
    ]}
  />
</Base>
