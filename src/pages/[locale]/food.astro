---
import Base from "../../layouts/Base.astro";
import ResourceLink from "../../components/ResourceLink.astro";
import { t, localePath, type Locale } from "../../i18n";

export function getStaticPaths() {
  return [
    { params: { locale: "es" } },
    { params: { locale: "zh" } },
    { params: { locale: "vi" } },
    { params: { locale: "tl" } },
  ];
}

const locale = Astro.params.locale as Locale;
---

<Base
  title={`${t(locale, "food.title")} — ${t(locale, "site.title")}`}
  lang={locale}
  currentPath="/food"
>
  <div class="mx-auto max-w-3xl px-4 py-10 sm:px-6 sm:py-16">
    <h1 class="text-center text-3xl font-bold sm:text-4xl">
      {t(locale, "food.title")}
    </h1>
    <p class="mt-3 text-center text-base text-gray-300 sm:mt-4 sm:text-lg">
      {t(locale, "food.pageDesc")}
    </p>

    <section class="mt-8 sm:mt-10">
      <h2 class="text-center text-xl font-bold sm:text-2xl">
        <span class="text-flag-red">[[[</span> ★ {
          t(locale, "common.knowYourRights")
        } ★ <span class="text-flag-red">]]]</span>
      </h2>
      <div class="mt-4 grid gap-3">
        <ResourceLink
          href="https://www.fns.usda.gov/snap/recipient/eligibility"
          title={t(locale, "food.snapEligibility")}
          description={t(locale, "food.snapEligibilityDesc")}
        />
        <ResourceLink
          href="https://www.fns.usda.gov/cn/applying-free-and-reduced-price-school-meals"
          title={t(locale, "food.schoolMeals")}
          description={t(locale, "food.schoolMealsDesc")}
        />
      </div>
    </section>

    <section class="mt-8 sm:mt-10">
      <h2 class="text-center text-xl font-bold sm:text-2xl">
        [[[ ★ {t(locale, "common.getHelp")} ★ ]]]
      </h2>
      <div class="mt-4 grid gap-3">
        <ResourceLink
          href="https://www.feedingamerica.org/find-your-local-foodbank"
          title={t(locale, "food.foodBank")}
          description={t(locale, "food.foodBankDesc")}
        />
        <ResourceLink
          href="https://www.fns.usda.gov/snap/state-directory"
          title={t(locale, "food.snapApply")}
          description={t(locale, "food.snapApplyDesc")}
        />
      </div>
    </section>

    <section class="mt-8 sm:mt-10">
      <h2 class="text-center text-xl font-bold sm:text-2xl">
        <span class="text-flag-blue">[[[</span> ★ {t(locale, "common.callNow")} ★
        <span class="text-flag-blue">]]]</span>
      </h2>
      <div class="mt-4 grid gap-3">
        <a
          href="tel:+18663486479"
          class="block rounded-lg border border-neutral-800 px-4 py-3.5 transition-colors hover:border-neutral-600 hover:bg-neutral-900 sm:px-5 sm:py-4"
        >
          <span class="font-bold">{t(locale, "food.phone")}</span>
          <span class="mt-1 block text-sm text-gray-400"
            >{t(locale, "food.phoneDesc")}</span
          >
        </a>
      </div>
    </section>

    <a
      href={localePath(locale, "/")}
      class="mt-10 block text-center text-gray-400 hover:text-white sm:mt-12"
      >[[[ {t(locale, "common.home")} ]]]</a
    >
  </div>
</Base>
