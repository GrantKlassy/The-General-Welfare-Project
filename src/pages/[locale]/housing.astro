---
import Base from "../../layouts/Base.astro";
import CategorySection from "../../components/CategorySection.astro";
import { t, type Locale } from "../../i18n";

export function getStaticPaths() {
  return [
    { params: { locale: "es" } },
    { params: { locale: "zh-Hans" } },
    { params: { locale: "vi" } },
    { params: { locale: "fil" } },
    { params: { locale: "ko" } },
    { params: { locale: "ja" } },
    { params: { locale: "ar" } },
    { params: { locale: "ht" } },
  ];
}

const locale = Astro.params.locale as Locale;
---

<Base
  title={`${t(locale, "housing.title")} — ${t(locale, "site.title")}`}
  lang={locale}
  currentPath="/housing"
>
  <CategorySection
    locale={locale}
    title={t(locale, "housing.title")}
    intro={t(locale, "housing.pageDesc")}
    callNow={[
      {
        tel: "211",
        label: t(locale, "housing.phone"),
        desc: t(locale, "housing.phoneDesc"),
      },
    ]}
    getHelp={[
      {
        href: "https://www.hud.gov/topics/rental_assistance",
        title: t(locale, "housing.assistance"),
        description: t(locale, "housing.assistanceDesc"),
      },
      {
        href: "https://www.lsc.gov/about-lsc/what-legal-aid/get-legal-help",
        title: t(locale, "housing.legalAid"),
        description: t(locale, "housing.legalAidDesc"),
      },
    ]}
    knowYourRights={[
      {
        href: "https://www.hud.gov/topics/rental_assistance/tenantrights",
        title: t(locale, "housing.tenantRights"),
        description: t(locale, "housing.tenantRightsDesc"),
      },
      {
        href: "https://www.lawhelp.org",
        title: t(locale, "housing.eviction"),
        description: t(locale, "housing.evictionDesc"),
      },
    ]}
  />
</Base>
