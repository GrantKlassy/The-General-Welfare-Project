---
import Base from "../../layouts/Base.astro";
import ResourceLink from "../../components/ResourceLink.astro";
import { t, localePath, type Locale } from "../../i18n";

export function getStaticPaths() {
  return [
    { params: { locale: "es" } },
    { params: { locale: "zh" } },
    { params: { locale: "vi" } },
  ];
}

const locale = Astro.params.locale as Locale;
---

<Base
  title={`${t(locale, "housing.title")} — ${t(locale, "site.title")}`}
  lang={locale}
  currentPath="/housing"
>
  <div class="mx-auto max-w-3xl px-6 py-16">
    <h1 class="text-4xl font-bold">{t(locale, "housing.title")}</h1>
    <p class="mt-4 text-lg text-gray-300">
      {t(locale, "housing.pageDesc")}
    </p>

    <section class="mt-10">
      <h2 class="text-2xl font-bold"><span class="text-flag-red">[</span> ★ {t(locale, "common.knowYourRights")} ★ <span class="text-flag-red">]</span></h2>
      <div class="mt-4 grid gap-3">
        <ResourceLink
          href="#"
          title={t(locale, "housing.tenantRights")}
          description={t(locale, "housing.tenantRightsDesc")}
        />
        <ResourceLink
          href="#"
          title={t(locale, "housing.eviction")}
          description={t(locale, "housing.evictionDesc")}
        />
      </div>
    </section>

    <section class="mt-10">
      <h2 class="text-2xl font-bold">[ ★ {t(locale, "common.getHelp")} ★ ]</h2>
      <div class="mt-4 grid gap-3">
        <ResourceLink
          href="#"
          title={t(locale, "housing.assistance")}
          description={t(locale, "housing.assistanceDesc")}
        />
        <ResourceLink
          href="#"
          title={t(locale, "housing.legalAid")}
          description={t(locale, "housing.legalAidDesc")}
        />
      </div>
    </section>

    <section class="mt-10">
      <h2 class="text-2xl font-bold"><span class="text-flag-blue">[</span> ★ {t(locale, "common.callNow")} ★ <span class="text-flag-blue">]</span></h2>
      <div class="mt-4 grid gap-3">
        <a
          href="tel:211"
          class="block rounded-lg border border-neutral-800 px-5 py-4 transition-colors hover:border-neutral-600 hover:bg-neutral-900"
        >
          <span class="font-bold">{t(locale, "housing.phone")}</span>
          <span class="mt-1 block text-sm text-gray-400"
            >{t(locale, "housing.phoneDesc")}</span
          >
        </a>
      </div>
    </section>

    <a
      href={localePath(locale, "/")}
      class="mt-12 inline-block text-gray-400 hover:text-white"
      >&larr; {t(locale, "common.allTopics")}</a
    >
  </div>
</Base>
