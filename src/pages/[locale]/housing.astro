---
import Base from "../../layouts/Base.astro";
import ResourceLink from "../../components/ResourceLink.astro";
import { t, localePath, type Locale } from "../../i18n";

export function getStaticPaths() {
  return [
    { params: { locale: "es" } },
    { params: { locale: "zh" } },
    { params: { locale: "vi" } },
  ];
}

const locale = Astro.params.locale as Locale;
---

<Base
  title={`${t(locale, "housing.title")} — ${t(locale, "site.title")}`}
  lang={locale}
  currentPath="/housing"
>
  <div class="mx-auto max-w-3xl px-4 py-10 sm:px-6 sm:py-16">
    <h1 class="text-center text-3xl font-bold sm:text-4xl">
      {t(locale, "housing.title")}
    </h1>
    <p class="mt-3 text-center text-base text-gray-300 sm:mt-4 sm:text-lg">
      {t(locale, "housing.pageDesc")}
    </p>

    <section class="mt-8 sm:mt-10">
      <h2 class="text-center text-xl font-bold sm:text-2xl">
        <span class="text-flag-red">[[[</span> ★ {
          t(locale, "common.knowYourRights")
        } ★ <span class="text-flag-red">]]]</span>
      </h2>
      <div class="mt-4 grid gap-3">
        <ResourceLink
          href="https://www.hud.gov/topics/rental_assistance/tenantrights"
          title={t(locale, "housing.tenantRights")}
          description={t(locale, "housing.tenantRightsDesc")}
        />
        <ResourceLink
          href="https://www.lawhelp.org"
          title={t(locale, "housing.eviction")}
          description={t(locale, "housing.evictionDesc")}
        />
      </div>
    </section>

    <section class="mt-8 sm:mt-10">
      <h2 class="text-center text-xl font-bold sm:text-2xl">
        [[[ ★ {t(locale, "common.getHelp")} ★ ]]]
      </h2>
      <div class="mt-4 grid gap-3">
        <ResourceLink
          href="https://www.hud.gov/topics/rental_assistance"
          title={t(locale, "housing.assistance")}
          description={t(locale, "housing.assistanceDesc")}
        />
        <ResourceLink
          href="https://www.lsc.gov/about-lsc/what-legal-aid/get-legal-help"
          title={t(locale, "housing.legalAid")}
          description={t(locale, "housing.legalAidDesc")}
        />
      </div>
    </section>

    <section class="mt-8 sm:mt-10">
      <h2 class="text-center text-xl font-bold sm:text-2xl">
        <span class="text-flag-blue">[[[</span> ★ {t(locale, "common.callNow")} ★
        <span class="text-flag-blue">]]]</span>
      </h2>
      <div class="mt-4 grid gap-3">
        <a
          href="tel:211"
          class="block rounded-lg border border-neutral-800 px-4 py-3.5 transition-colors hover:border-neutral-600 hover:bg-neutral-900 sm:px-5 sm:py-4"
        >
          <span class="font-bold">{t(locale, "housing.phone")}</span>
          <span class="mt-1 block text-sm text-gray-400"
            >{t(locale, "housing.phoneDesc")}</span
          >
        </a>
      </div>
    </section>

    <a
      href={localePath(locale, "/")}
      class="mt-10 block text-center text-gray-400 hover:text-white sm:mt-12"
      >&larr; {t(locale, "common.allTopics")}</a
    >
  </div>
</Base>
