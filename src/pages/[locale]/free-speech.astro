---
import Base from "../../layouts/Base.astro";
import ResourceLink from "../../components/ResourceLink.astro";
import { t, localePath, type Locale } from "../../i18n";

export function getStaticPaths() {
  return [
    { params: { locale: "es" } },
    { params: { locale: "zh" } },
    { params: { locale: "vi" } },
  ];
}

const locale = Astro.params.locale as Locale;
---

<Base
  title={`${t(locale, "freeSpeech.title")} — ${t(locale, "site.title")}`}
  lang={locale}
  currentPath="/free-speech"
>
  <div class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
    <h1 class="text-center text-4xl font-bold">{t(locale, "freeSpeech.title")}</h1>
    <p class="mt-4 text-center text-lg text-gray-300">
      {t(locale, "freeSpeech.pageDesc")}
    </p>

    <section class="mt-10">
      <h2 class="text-center text-xl font-bold sm:text-2xl"><span class="text-flag-red">[[[</span> ★ {t(locale, "common.knowYourRights")} ★ <span class="text-flag-red">]]]</span></h2>
      <div class="mt-4 grid gap-3">
        <ResourceLink
          href="https://www.aclu.org/issues/free-speech"
          title={t(locale, "freeSpeech.firstAmendment")}
          description={t(locale, "freeSpeech.firstAmendmentDesc")}
        />
        <ResourceLink
          href="https://www.aclu.org/know-your-rights/protesters-rights"
          title={t(locale, "freeSpeech.protest")}
          description={t(locale, "freeSpeech.protestDesc")}
        />
      </div>
    </section>

    <section class="mt-10">
      <h2 class="text-center text-xl font-bold sm:text-2xl">[[[ ★ {t(locale, "common.getHelp")} ★ ]]]</h2>
      <div class="mt-4 grid gap-3">
        <ResourceLink
          href="https://www.aclu.org/contact-us"
          title={t(locale, "freeSpeech.legalSupport")}
          description={t(locale, "freeSpeech.legalSupportDesc")}
        />
        <ResourceLink
          href="https://www.nlg.org/know-your-rights/"
          title={t(locale, "freeSpeech.knowRightsProtest")}
          description={t(locale, "freeSpeech.knowRightsProtestDesc")}
        />
      </div>
    </section>

    <section class="mt-10">
      <h2 class="text-center text-xl font-bold sm:text-2xl"><span class="text-flag-blue">[[[</span> ★ {t(locale, "common.callNow")} ★ <span class="text-flag-blue">]]]</span></h2>
      <div class="mt-4 grid gap-3">
        <a
          href="tel:212-679-5100"
          class="block rounded-lg border border-neutral-800 px-5 py-4 transition-colors hover:border-neutral-600 hover:bg-neutral-900"
        >
          <span class="font-bold">{t(locale, "freeSpeech.phone")}</span>
          <span class="mt-1 block text-sm text-gray-400"
            >{t(locale, "freeSpeech.phoneDesc")}</span
          >
        </a>
      </div>
    </section>

    <a
      href={localePath(locale, "/")}
      class="mt-12 block text-center text-gray-400 hover:text-white"
      >&larr; {t(locale, "common.allTopics")}</a
    >
  </div>
</Base>
