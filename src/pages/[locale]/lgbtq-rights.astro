---
import Base from "../../layouts/Base.astro";
import CategorySection from "../../components/CategorySection.astro";
import { t, type Locale } from "../../i18n";

export function getStaticPaths() {
  return [
    { params: { locale: "es" } },
    { params: { locale: "zh-Hans" } },
    { params: { locale: "vi" } },
    { params: { locale: "fil" } },
    { params: { locale: "ko" } },
    { params: { locale: "ja" } },
  ];
}

const locale = Astro.params.locale as Locale;
---

<Base
  title={`${t(locale, "lgbtq.title")} — ${t(locale, "site.title")}`}
  lang={locale}
  currentPath="/lgbtq-rights"
>
  <CategorySection
    locale={locale}
    title={t(locale, "lgbtq.title")}
    intro={t(locale, "lgbtq.pageDesc")}
    callNow={[
      {
        tel: "988",
        label: t(locale, "lgbtq.phone988"),
        desc: t(locale, "lgbtq.phone988Desc"),
      },
      {
        tel: "866-488-7386",
        label: t(locale, "lgbtq.phoneTrevor"),
        desc: t(locale, "lgbtq.phoneTrevorDesc"),
      },
    ]}
    getHelp={[
      {
        href: "https://www.lambdalegal.org/helpdesk",
        title: t(locale, "lgbtq.legalSupport"),
        description: t(locale, "lgbtq.legalSupportDesc"),
      },
      {
        href: "https://www.lgbthotline.org",
        title: t(locale, "lgbtq.crisisResources"),
        description: t(locale, "lgbtq.crisisResourcesDesc"),
      },
    ]}
    knowYourRights={[
      {
        href: "https://www.eeoc.gov/filing-charge-discrimination",
        title: t(locale, "lgbtq.antiDiscrimination"),
        description: t(locale, "lgbtq.antiDiscriminationDesc"),
      },
      {
        href: "https://transequality.org/documents",
        title: t(locale, "lgbtq.transRights"),
        description: t(locale, "lgbtq.transRightsDesc"),
      },
    ]}
  />
</Base>
