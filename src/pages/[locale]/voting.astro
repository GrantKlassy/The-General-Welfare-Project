---
import Base from "../../layouts/Base.astro";
import CategorySection from "../../components/CategorySection.astro";
import { t, type Locale } from "../../i18n";

export function getStaticPaths() {
  return [
    { params: { locale: "es" } },
    { params: { locale: "zh-Hans" } },
    { params: { locale: "vi" } },
    { params: { locale: "fil" } },
  ];
}

const locale = Astro.params.locale as Locale;
---

<Base
  title={`${t(locale, "voting.title")} — ${t(locale, "site.title")}`}
  lang={locale}
  currentPath="/voting"
>
  <CategorySection
    locale={locale}
    title={t(locale, "voting.title")}
    intro={t(locale, "voting.pageDesc")}
    callNow={[
      {
        tel: "866-687-8683",
        label: t(locale, "voting.phone"),
        desc: t(locale, "voting.phoneDesc"),
      },
    ]}
    getHelp={[
      {
        href: "https://www.vote.org/polling-place-locator/",
        title: t(locale, "voting.pollingPlace"),
        description: t(locale, "voting.pollingPlaceDesc"),
      },
      {
        href: "https://866ourvote.org",
        title: t(locale, "voting.electionProtection"),
        description: t(locale, "voting.electionProtectionDesc"),
      },
    ]}
    knowYourRights={[
      {
        href: "https://vote.gov",
        title: t(locale, "voting.registration"),
        description: t(locale, "voting.registrationDesc"),
      },
      {
        href: "https://www.vote.org/voter-id-laws/",
        title: t(locale, "voting.voterId"),
        description: t(locale, "voting.voterIdDesc"),
      },
    ]}
  />
</Base>
