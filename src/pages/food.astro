---
import Base from "../layouts/Base.astro";
import CategorySection from "../components/CategorySection.astro";
import { t } from "../i18n";
---

<Base
  title={`${t("en", "food.title")} — ${t("en", "site.title")}`}
  currentPath="/food"
>
  <CategorySection
    locale="en"
    title={t("en", "food.title")}
    intro={t("en", "food.pageDesc")}
    callNow={[
      {
        tel: "+18663486479",
        label: t("en", "food.phone"),
        desc: t("en", "food.phoneDesc"),
      },
    ]}
    getHelp={[
      {
        href: "https://www.feedingamerica.org/find-your-local-foodbank",
        title: t("en", "food.foodBank"),
        description: t("en", "food.foodBankDesc"),
      },
      {
        href: "https://www.fns.usda.gov/snap/state-directory",
        title: t("en", "food.snapApply"),
        description: t("en", "food.snapApplyDesc"),
      },
    ]}
    knowYourRights={[
      {
        href: "https://www.fns.usda.gov/snap/recipient/eligibility",
        title: t("en", "food.snapEligibility"),
        description: t("en", "food.snapEligibilityDesc"),
      },
      {
        href: "https://www.fns.usda.gov/cn/applying-free-and-reduced-price-school-meals",
        title: t("en", "food.schoolMeals"),
        description: t("en", "food.schoolMealsDesc"),
      },
    ]}
  />
</Base>
