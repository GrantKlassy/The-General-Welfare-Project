---
import Base from "../layouts/Base.astro";
import CategorySection from "../components/CategorySection.astro";
import { t } from "../i18n";
---

<Base
  title={`${t("en", "lgbtq.title")} — ${t("en", "site.title")}`}
  currentPath="/lgbtq-rights"
>
  <CategorySection
    locale="en"
    title={t("en", "lgbtq.title")}
    intro={t("en", "lgbtq.pageDesc")}
    callNow={[
      {
        tel: "988",
        label: t("en", "lgbtq.phone988"),
        desc: t("en", "lgbtq.phone988Desc"),
      },
      {
        tel: "866-488-7386",
        label: t("en", "lgbtq.phoneTrevor"),
        desc: t("en", "lgbtq.phoneTrevorDesc"),
      },
    ]}
    getHelp={[
      {
        href: "https://www.lambdalegal.org/helpdesk",
        title: t("en", "lgbtq.legalSupport"),
        description: t("en", "lgbtq.legalSupportDesc"),
      },
      {
        href: "https://www.lgbthotline.org",
        title: t("en", "lgbtq.crisisResources"),
        description: t("en", "lgbtq.crisisResourcesDesc"),
      },
    ]}
    knowYourRights={[
      {
        href: "https://www.eeoc.gov/filing-charge-discrimination",
        title: t("en", "lgbtq.antiDiscrimination"),
        description: t("en", "lgbtq.antiDiscriminationDesc"),
      },
      {
        href: "https://transequality.org/documents",
        title: t("en", "lgbtq.transRights"),
        description: t("en", "lgbtq.transRightsDesc"),
      },
    ]}
  />
</Base>
