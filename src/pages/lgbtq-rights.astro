---
import Base from "../layouts/Base.astro";
import ResourceLink from "../components/ResourceLink.astro";
---

<Base title="LGBTQ+ Rights --- The General Welfare Project" currentPath="/lgbtq-rights">
  <div class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
    <h1 class="text-center text-4xl font-bold">LGBTQ+ Rights</h1>
    <p class="mt-4 text-center text-lg text-gray-300">
      Anti-discrimination protections, trans rights, and support organizations.
    </p>

    <section class="mt-10">
      <h2 class="text-center text-xl font-bold sm:text-2xl"><span class="text-flag-red">[[[</span> ★ Know Your Rights ★ <span class="text-flag-red">]]]</span></h2>
      <div class="mt-4 grid gap-3">
        <ResourceLink
          href="https://www.eeoc.gov/filing-charge-discrimination"
          title="Discrimination Based on Identity Is Illegal"
          description="Federal law prohibits discrimination at work, in housing, and in public spaces based on who you are. If you have experienced discrimination, you can file a charge here."
        />
        <ResourceLink
          href="https://transequality.org/documents"
          title="Updating Your Name and ID Documents"
          description="Step-by-step guides to changing your name, gender marker on IDs, and accessing healthcare --- for every state."
        />
      </div>
    </section>

    <section class="mt-10">
      <h2 class="text-center text-xl font-bold sm:text-2xl">[[[ ★ Get Help ★ ]]]</h2>
      <div class="mt-4 grid gap-3">
        <ResourceLink
          href="https://www.lambdalegal.org/helpdesk"
          title="Free Legal Help Is Available"
          description="Lambda Legal's help desk takes cases for free. If you have been discriminated against, fired, denied housing, or denied healthcare because of who you are --- you can contact them for assistance."
        />
        <ResourceLink
          href="https://www.lgbthotline.org"
          title="Talk to Someone Who Understands"
          description="Confidential peer support from people who understand. Chat, text, or call --- available to any LGBTQ+ person, not only during crisis situations."
        />
      </div>
    </section>

    <section class="mt-10">
      <h2 class="text-center text-xl font-bold sm:text-2xl"><span class="text-flag-blue">[[[</span> ★ Call Now ★ <span class="text-flag-blue">]]]</span></h2>
      <div class="mt-4 grid gap-3">
        <a
          href="tel:988"
          class="block rounded-lg border border-neutral-800 px-5 py-4 transition-colors hover:border-neutral-600 hover:bg-neutral-900"
        >
          <span class="font-bold">988</span>
          <span class="mt-1 block text-sm text-gray-400"
            >Suicide & Crisis Lifeline --- press 3 for LGBTQ+ support</span
          >
        </a>
        <a
          href="tel:866-488-7386"
          class="block rounded-lg border border-neutral-800 px-5 py-4 transition-colors hover:border-neutral-600 hover:bg-neutral-900"
        >
          <span class="font-bold">866-488-7386</span>
          <span class="mt-1 block text-sm text-gray-400"
            >The Trevor Project --- crisis support for LGBTQ+ youth</span
          >
        </a>
      </div>
    </section>

    <a href="/" class="mt-12 block text-center text-gray-400 hover:text-white"
      >&larr; All topics</a
    >
  </div>
</Base>
