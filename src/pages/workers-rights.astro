---
import Base from "../layouts/Base.astro";
import ResourceLink from "../components/ResourceLink.astro";
---

<Base title="Workers' Rights --- The General Welfare Project" currentPath="/workers-rights">
  <div class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
    <h1 class="text-center text-4xl font-bold">Workers' Rights</h1>
    <p class="mt-4 text-center text-lg text-gray-300">
      Wage theft, workplace safety, labor board complaints, and unemployment
      insurance.
    </p>

    <section class="mt-10">
      <h2 class="text-center text-xl font-bold sm:text-2xl"><span class="text-flag-red">[[[</span> ★ Know Your Rights ★ <span class="text-flag-red">]]]</span></h2>
      <div class="mt-4 grid gap-3">
        <ResourceLink
          href="https://www.dol.gov/agencies/whd/workers"
          title="You Are Entitled to Every Dollar You Earned"
          description="Wage theft is the most common form of theft in America. If you were not paid minimum wage, overtime, or your tips were taken --- the law protects you."
        />
        <ResourceLink
          href="https://www.osha.gov/workers/file-complaint"
          title="You Can Report Unsafe Conditions Confidentially"
          description="OSHA protects workers. You can file a confidential complaint about unsafe conditions, and your employer cannot legally retaliate."
        />
      </div>
    </section>

    <section class="mt-10">
      <h2 class="text-center text-xl font-bold sm:text-2xl">[[[ ★ Get Help ★ ]]]</h2>
      <div class="mt-4 grid gap-3">
        <ResourceLink
          href="https://www.dol.gov/agencies/whd/contact/complaints"
          title="File a Wage Theft Complaint --- No Cost"
          description="The Department of Labor will investigate your employer at no cost. You do not need a lawyer. File online now."
        />
        <ResourceLink
          href="https://www.careeronestop.org/LocalHelp/UnemploymentBenefits/find-unemployment-benefits.aspx"
          title="Apply for Unemployment Benefits"
          description="If you lost your job, you likely qualify. Every state has an online application. You have paid into this system --- these are benefits you have earned."
        />
      </div>
    </section>

    <section class="mt-10">
      <h2 class="text-center text-xl font-bold sm:text-2xl"><span class="text-flag-blue">[[[</span> ★ Call Now ★ <span class="text-flag-blue">]]]</span></h2>
      <div class="mt-4 grid gap-3">
        <a
          href="tel:1-866-487-2365"
          class="block rounded-lg border border-neutral-800 px-5 py-4 transition-colors hover:border-neutral-600 hover:bg-neutral-900"
        >
          <span class="font-bold">1-866-4-USWAGE (1-866-487-2365)</span>
          <span class="mt-1 block text-sm text-gray-400"
            >Department of Labor --- wage and hour violations</span
          >
        </a>
      </div>
    </section>

    <a href="/" class="mt-12 block text-center text-gray-400 hover:text-white"
      >&larr; All topics</a
    >
  </div>
</Base>
