---
import Base from "../layouts/Base.astro";
import CategorySection from "../components/CategorySection.astro";
import { t } from "../i18n";
---

<Base
  title={`${t("en", "workers.title")} — ${t("en", "site.title")}`}
  currentPath="/workers-rights"
>
  <CategorySection
    locale="en"
    title={t("en", "workers.title")}
    intro={t("en", "workers.pageDesc")}
    callNow={[
      {
        tel: "1-866-487-2365",
        label: t("en", "workers.phone"),
        desc: t("en", "workers.phoneDesc"),
      },
    ]}
    getHelp={[
      {
        href: "https://www.dol.gov/agencies/whd/contact/complaints",
        title: t("en", "workers.complaint"),
        description: t("en", "workers.complaintDesc"),
      },
      {
        href: "https://www.careeronestop.org/LocalHelp/UnemploymentBenefits/find-unemployment-benefits.aspx",
        title: t("en", "workers.unemployment"),
        description: t("en", "workers.unemploymentDesc"),
      },
    ]}
    knowYourRights={[
      {
        href: "https://www.dol.gov/agencies/whd/workers",
        title: t("en", "workers.wageHour"),
        description: t("en", "workers.wageHourDesc"),
      },
      {
        href: "https://www.osha.gov/workers/file-complaint",
        title: t("en", "workers.safety"),
        description: t("en", "workers.safetyDesc"),
      },
    ]}
  />
</Base>
