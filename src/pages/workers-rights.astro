---
import Base from "../layouts/Base.astro";
import ResourceLink from "../components/ResourceLink.astro";
---

<Base title="Workers' Rights — The General Welfare Project" currentPath="/workers-rights">
  <div class="mx-auto max-w-3xl px-6 py-16">
    <h1 class="text-4xl font-bold">Workers' Rights</h1>
    <p class="mt-4 text-lg text-gray-300">
      Wage theft, workplace safety, labor board complaints, and unemployment
      insurance.
    </p>

    <section class="mt-10">
      <h2 class="text-2xl font-bold"><span class="text-flag-red">[[[</span> ★ Know Your Rights ★ <span class="text-flag-red">]]]</span></h2>
      <div class="mt-4 grid gap-3">
        <ResourceLink
          href="https://www.dol.gov/agencies/whd/workers"
          title="Your Boss Owes You Every Dollar You Earned"
          description="Wage theft is the largest form of theft in America. If you weren't paid minimum wage, overtime, or your tips were taken — the law is on your side."
        />
        <ResourceLink
          href="https://www.osha.gov/workers/file-complaint"
          title="You Can Report Unsafe Working Conditions Anonymously"
          description="OSHA protects you. You can file a confidential complaint about unsafe conditions, and your employer can't legally retaliate against you."
        />
      </div>
    </section>

    <section class="mt-10">
      <h2 class="text-2xl font-bold">[[[ ★ Get Help ★ ]]]</h2>
      <div class="mt-4 grid gap-3">
        <ResourceLink
          href="https://www.dol.gov/agencies/whd/contact/complaints"
          title="File a Wage Theft Complaint — It's Free"
          description="The Department of Labor will investigate your employer for free. You don't need a lawyer. File online right now."
        />
        <ResourceLink
          href="https://www.careeronestop.org/LocalHelp/UnemploymentBenefits/find-unemployment-benefits.aspx"
          title="Apply for Unemployment Benefits Today"
          description="If you lost your job, you likely qualify. Every state has an online application. You paid into this system — this is YOUR money."
        />
      </div>
    </section>

    <section class="mt-10">
      <h2 class="text-2xl font-bold"><span class="text-flag-blue">[[[</span> ★ Call Now ★ <span class="text-flag-blue">]]]</span></h2>
      <div class="mt-4 grid gap-3">
        <a
          href="tel:1-866-487-2365"
          class="block rounded-lg border border-neutral-800 px-5 py-4 transition-colors hover:border-neutral-600 hover:bg-neutral-900"
        >
          <span class="font-bold">1-866-4-USWAGE (1-866-487-2365)</span>
          <span class="mt-1 block text-sm text-gray-400"
            >Department of Labor — wage and hour violations</span
          >
        </a>
      </div>
    </section>

    <a href="/" class="mt-12 inline-block text-gray-400 hover:text-white"
      >&larr; All topics</a
    >
  </div>
</Base>
