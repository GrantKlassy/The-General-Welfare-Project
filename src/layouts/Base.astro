---
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
import type { Locale } from "../i18n";

interface Props {
  title: string;
  description?: string;
  lang?: Locale;
  currentPath?: string;
}

const {
  title,
  description = "The General Welfare Project",
  lang = "en",
  currentPath = "/",
} = Astro.props;

const dir = lang === "ar" ? "rtl" : "ltr";
---

<!doctype html>
<html lang={lang} dir={dir}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0a" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link
      rel="preload"
      href="/fonts/inclusive-sans-v4-latin-regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/inclusive-sans-v4-latin-700.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <style is:inline>
      @font-face {
        font-family: "Inclusive Sans";
        src: url("/fonts/inclusive-sans-v4-latin-regular.woff2") format("woff2");
        font-weight: normal;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: "Inclusive Sans";
        src: url("/fonts/inclusive-sans-v4-latin-700.woff2") format("woff2");
        font-weight: bold;
        font-style: normal;
        font-display: swap;
      }
    </style>
    {
      lang === "zh-Hans" && (
        <style
          is:inline
          set:html={`body { font-family: "PingFang SC", "Microsoft YaHei", "Noto Sans SC", sans-serif; }`}
        />
      )
    }
    {
      lang === "ko" && (
        <style
          is:inline
          set:html={`body { font-family: "Apple SD Gothic Neo", "Malgun Gothic", "Noto Sans KR", sans-serif; }`}
        />
      )
    }
    {
      lang === "ja" && (
        <style
          is:inline
          set:html={`body { font-family: "Hiragino Sans", "Yu Gothic", "Meiryo", "Noto Sans JP", sans-serif; }`}
        />
      )
    }
    {
      lang === "ar" && (
        <style
          is:inline
          set:html={`body { font-family: "SF Arabic", "Geeza Pro", "Noto Sans Arabic", "Segoe UI", Tahoma, sans-serif; }`}
        />
      )
    }
  </head>
  <body class="min-h-screen font-sans antialiased">
    <Nav locale={lang} currentPath={currentPath} />
    <main>
      <slot />
    </main>
    <Footer locale={lang} currentPath={currentPath} />
  </body>
</html>
