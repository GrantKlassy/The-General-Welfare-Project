---
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
import type { Locale } from "../i18n";

interface Props {
  title: string;
  description?: string;
  lang?: Locale;
  currentPath?: string;
}

const {
  title,
  description = "The General Welfare Project",
  lang = "en",
  currentPath = "/",
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#000000" />
    <link rel="icon" type="image/png" href="/favicon.png" />

    <link
      rel="preload"
      href="/fonts/inclusive-sans-v4-latin-regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/inclusive-sans-v4-latin-700.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <style is:inline>
      body {
        opacity: 0;
        transition: opacity 0.05s ease-in;
      }
      body.ready {
        opacity: 1;
      }
      @font-face {
        font-family: "Inclusive Sans";
        src: url("/fonts/inclusive-sans-v4-latin-regular.woff2") format("woff2");
        font-weight: normal;
        font-style: normal;
        font-display: block;
      }
      @font-face {
        font-family: "Inclusive Sans";
        src: url("/fonts/inclusive-sans-v4-latin-700.woff2") format("woff2");
        font-weight: bold;
        font-style: normal;
        font-display: block;
      }
    </style>
    {
      lang === "zh" && (
        <style is:inline>
          body {
            font-family: "PingFang SC", "Microsoft YaHei", "Noto Sans SC",
              sans-serif;
          }
        </style>
      )
    }
  </head>
  <body class="min-h-screen font-sans antialiased">
    <Nav locale={lang} currentPath={currentPath} />
    <main>
      <slot />
    </main>
    <Footer locale={lang} />

    <script is:inline>
      const reveal = () => document.body.classList.add("ready");
      if (document.fonts?.ready) {
        document.fonts.ready.then(reveal);
      }
      setTimeout(reveal, 300);
    </script>
  </body>
</html>
